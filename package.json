{
  "name": "nri-office-tour-stamp-rally",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "npm run generate:icons",
    "build": "vite build && node scripts/verify-build.mjs",
    "prebuild": "npm run clean:dist && npm run generate:icons",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "check": "npm run lint && npm run test:run && npm run build",
    "generate:icons": "node scripts/generate-icons.mjs",
    "clean:dist": "node scripts/clean-dist.mjs"
  },
  "dependencies": {
    "zxing-wasm": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
